{
  "name": "offload-project/laravel-mandate",
  "description": "Unified authorization management for Laravel - roles, permissions, and feature flags in a type-safe API",
  "keywords": [
    "laravel",
    "permissions",
    "roles",
    "feature-flags",
    "pennant",
    "authorization",
    "rbac"
  ],
  "homepage": "https://github.com/offload-project/laravel-mandate",
  "license": "MIT",
  "authors": [
    {
      "name": "Offload Project"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^11.0|^12.0|^13.0",
    "illuminate/console": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "captainhook/captainhook-phar": "^5.28",
    "larastan/larastan": "^3.9.2",
    "laravel/pint": "^1.26.1",
    "mockery/mockery": "^1.6.12",
    "orchestra/testbench": "^9.0|^10.8|^11.0",
    "pestphp/pest": "^3.0|^4.0",
    "pestphp/pest-plugin-laravel": "^3.0|^4.0",
    "ramsey/conventional-commits": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "OffloadProject\\Mandate\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OffloadProject\\Mandate\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "@php vendor/bin/pest",
    "test-coverage": "@php vendor/bin/pest --coverage",
    "analyse": "phpstan analyse --memory-limit=-1",
    "analyse-baseline": "phpstan analyse --memory-limit=-1 --generate-baseline",
    "pint": "vendor/bin/pint",
    "install-hooks": "vendor/bin/captainhook install --only-enabled"
  },
  "extra": {
    "laravel": {
      "providers": [
        "OffloadProject\\Mandate\\MandateServiceProvider"
      ],
      "aliases": {
        "Mandate": "OffloadProject\\Mandate\\Facades\\Mandate"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "captainhook/captainhook-phar": true,
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
